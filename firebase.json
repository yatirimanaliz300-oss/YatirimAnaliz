{
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".git",
      ".gitignore",
      "main.py",
      "baslat.bat",
      "Procfile",
      "requirements.txt",
      "__pycache__",
      "**/*.pyc",
      "node_modules",
      "firebase-debug.log"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
